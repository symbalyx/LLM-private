version: "3.8"

# ============================================================
#  Symbalyx Secure Messaging — Matrix Synapse + Element Web
#  + Element Call (group video, E2E via MatrixRTC + LiveKit SFU)
#  Stack 100% locale, chiffrement E2E natif, zéro cloud.
# ============================================================

services:

  postgres:
    image: postgres:16-alpine
    container_name: symbalyx_postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: synapse
      POSTGRES_PASSWORD: synapse_local_pw_change_me
      POSTGRES_DB: synapse
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --locale=C"
    volumes:
      - ./data/postgres:/var/lib/postgresql/data
    networks: [symbalyx_net]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U synapse"]
      interval: 10s
      timeout: 5s
      retries: 5

  synapse:
    image: matrixdotorg/synapse:latest
    container_name: symbalyx_synapse
    restart: unless-stopped
    depends_on:
      postgres: { condition: service_healthy }
    environment:
      SYNAPSE_SERVER_NAME: "localhost"
      SYNAPSE_REPORT_STATS: "no"
      UID: "991"
      GID: "991"
      TZ: "Europe/Paris"
    volumes:
      - ./data/synapse:/data
    ports:
      - "8008:8008"
    networks: [symbalyx_net]
    healthcheck:
      test: ["CMD", "curl", "-fSs", "http://localhost:8008/health"]
      interval: 15s
      timeout: 5s
      retries: 5

  element:
    image: vectorim/element-web:latest
    container_name: symbalyx_element
    restart: unless-stopped
    depends_on: [synapse]
    volumes:
      - ./element/config.json:/app/config.json:ro
      - ./element/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./element/symbalyx-element-ui.css:/app/symbalyx-element-ui.css:ro
      - ./element/symbalyx-element-ui.js:/app/symbalyx-element-ui.js:ro
    ports:
      - "8080:80"
    networks: [symbalyx_net]

  # ------------------------------------------------------------
  # LiveKit SFU — relais média pour les appels de groupe.
  # Les flux audio/vidéo restent E2EE (clés Megolm/MatrixRTC),
  # LiveKit ne relaye que du chiffré.
  # ------------------------------------------------------------
  livekit:
    image: livekit/livekit-server:latest
    container_name: symbalyx_livekit
    restart: unless-stopped
    command: --config /etc/livekit.yaml
    volumes:
      - ./config/livekit.yaml:/etc/livekit.yaml:ro
    network_mode: host

  # ------------------------------------------------------------
  # LiveKit JWT Service — convertit un access_token Matrix
  # en JWT LiveKit (validé contre Synapse).
  # ------------------------------------------------------------
  lk-jwt-service:
    image: ghcr.io/element-hq/lk-jwt-service:latest-ci
    container_name: symbalyx_lk_jwt
    restart: unless-stopped
    depends_on: [synapse, livekit]
    environment:
      LIVEKIT_URL: "ws://localhost:7880"
      LIVEKIT_KEY: "symbalyx_lk_key"
      LIVEKIT_SECRET: "symbalyx_lk_secret_change_me_min_32_chars"
      LK_JWT_PORT: "8881"
    ports:
      - "8881:8881"
    networks: [symbalyx_net]

  # ------------------------------------------------------------
  # Element Call — client d'appel vidéo de groupe E2EE
  # (basé sur MatrixRTC + WebRTC + LiveKit SFU).
  # ------------------------------------------------------------
  element-call:
    image: ghcr.io/element-hq/element-call:latest-ci
    container_name: symbalyx_element_call
    restart: unless-stopped
    depends_on: [synapse, lk-jwt-service]
    volumes:
      - ./element-call/config.json:/app/config.json:ro
    ports:
      - "8181:8080"
    networks: [symbalyx_net]

  # ------------------------------------------------------------
  # coturn — TURN/STUN pour les appels 1-to-1 (legacy WebRTC)
  # et le NAT-traversal en LAN/mobile.
  # ------------------------------------------------------------
  coturn:
    image: coturn/coturn:latest
    container_name: symbalyx_coturn
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./config/turnserver.conf:/etc/coturn/turnserver.conf:ro

  # ------------------------------------------------------------
  # Whisper ASR — transcription locale des messages vocaux
  # et des appels (zéro cloud). Modèle "small" par défaut.
  # ~1 Go d'image, 1-2 Go RAM. Tournage CPU only.
  # ------------------------------------------------------------
  whisper:
    image: onerahmet/openai-whisper-asr-webservice:latest
    container_name: symbalyx_whisper
    restart: unless-stopped
    environment:
      ASR_MODEL: "small"
      ASR_ENGINE: "openai_whisper"
    ports:
      - "9000:9000"
    networks: [symbalyx_net]

  # ------------------------------------------------------------
  # Ollama — LLM local pour résumés d'appels et assistant IA.
  # Modèle à pull manuellement après le premier démarrage :
  #   docker exec symbalyx_ollama ollama pull llama3.2:3b
  # ~2 Go disque, ~3-4 Go RAM en inférence. CPU only.
  # ------------------------------------------------------------
  ollama:
    image: ollama/ollama:latest
    container_name: symbalyx_ollama
    restart: unless-stopped
    volumes:
      - ./data/ollama:/root/.ollama
    ports:
      - "11434:11434"
    networks: [symbalyx_net]

  # ------------------------------------------------------------
  # Bot Assistant — compte Matrix qui écoute les invitations,
  # rejoint les conversations chiffrées (E2E Megolm via libolm),
  # et répond via Ollama. Plusieurs personas configurables.
  # Demande la création préalable du compte côté Synapse :
  #   docker exec symbalyx_synapse register_new_matrix_user \
  #     -u assistant -p VOTREMOTDEPASSE --no-admin \
  #     -c /data/homeserver.yaml http://localhost:8008
  # Puis configurer BOT_PASSWORD dans un fichier .env ou ici.
  # ------------------------------------------------------------
  assistant_bot:
    build: ./bots
    image: symbalyx-assistant-bot:latest
    container_name: symbalyx_assistant_bot
    restart: unless-stopped
    depends_on: [synapse, ollama]
    environment:
      HOMESERVER: "http://synapse:8008"
      SERVER_NAME: "localhost"
      BOT_USERNAME: "assistant"
      BOT_PASSWORD: "${ASSISTANT_BOT_PASSWORD:-}"
      OLLAMA_URL: "http://ollama:11434"
      OLLAMA_MODEL: "${OLLAMA_MODEL:-llama3.2:3b}"
      BOT_STORE: "/data/store"
      ASSISTANT_MEMORY_DIR: "/data/memory"
      ASSISTANT_GENERATED_DIR: "/data/generated"
      ASSISTANT_AUTO_MEMORY: "${ASSISTANT_AUTO_MEMORY:-true}"
      ASSISTANT_MAX_TURNS: "${ASSISTANT_MAX_TURNS:-12}"
      ASSISTANT_MAX_RECALL: "${ASSISTANT_MAX_RECALL:-6}"
    volumes:
      - ./data/assistant_bot:/data
    networks: [symbalyx_net]
    profiles: ["ia"]

  # ------------------------------------------------------------
  # UI Symbalyx — interface custom (sidebar, groupes,
  # timer messages éphémères, lancement d'appels).
  # ------------------------------------------------------------
  ui:
    image: nginx:alpine
    container_name: symbalyx_ui
    restart: unless-stopped
    volumes:
      - ./ui:/usr/share/nginx/html:ro
      - ./config/nginx-ui.conf:/etc/nginx/conf.d/default.conf:ro
    ports:
      - "8090:80"
    networks: [symbalyx_net]

  # ------------------------------------------------------------
  # Caddy — reverse proxy HTTPS single-origin.
  # Optionnel : démarrez ce service quand vous avez généré les
  # certificats mkcert dans ./certs/ (voir README · HTTPS local).
  # Si ./certs/ est absent, le service échouera proprement.
  # ------------------------------------------------------------
  caddy:
    image: caddy:2-alpine
    container_name: symbalyx_caddy
    restart: unless-stopped
    depends_on: [synapse, element, ui, whisper, element-call, lk-jwt-service]
    volumes:
      - ./config/Caddyfile:/etc/caddy/Caddyfile:ro
      - ./certs:/certs:ro
    ports:
      - "8443:8443"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks: [symbalyx_net]
    profiles: ["https"]

networks:
  symbalyx_net:
    driver: bridge
